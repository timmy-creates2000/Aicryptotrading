# .env.example — Copy this to .env and fill in your values

# Bybit Trading API Keys - DEMO (Testnet)
BYBIT_API_KEY_DEMO=your_demo_api_key_here
BYBIT_API_SECRET_DEMO=your_demo_api_secret_here

# Bybit Trading API Keys - REAL (Mainnet)
BYBIT_API_KEY_REAL=your_real_api_key_here
BYBIT_API_SECRET_REAL=your_real_api_secret_here

# Legacy format (still supported for backward compatibility)
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=False

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Server
PORT=8080

# Bot Control
AUTO_START_TRADING=false  # Set to 'true' to auto-start trading on deploy, 'false' to wait for /start command

# Optional: Telegram webhook settings
TELEGRAM_LOG_FILE=telegram_messages.log

# Optional: Render.com deployment
RENDER_EXTERNAL_URL=https://your-render-service-url.onrender.com
